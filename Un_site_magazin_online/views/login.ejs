<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
</head>
<body>
  <h1>Login</h1>

  <% if (error) { %>
    <p style="color:red;"><%= error %></p>
  <% } %>

  <form method="POST" action="/login">
    <div>
      <label>Email:</label>
      <input type="email" name="email" required />
    </div>
    <div>
      <label>Parola:</label>
      <input type="password" name="password" required />
    </div>
    <button type="submit">Login</button>
  </form>

  <p><a href="/">Înapoi la home</a></p>
</body>
</html>
